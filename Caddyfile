# This is your Caddy configuration. This default config
# opens a port and serves a static site from the www folder.
# Edit this file according to your needs.

# Remember, Railway terminates TLS before it gets to Caddy.

api.housetrap.ch:8080 {
    reverse_proxy /dc/* cantons-challenge-api.railway.internal:8000
    rate_limit {
        zone votes {
            match {
                path /dc/v1/vote
            }
            key {remote_host}
            events 100
            window 1m
        }
        jitter 0.1
    }
}

:8080 {
    root /www
    file_server
}